<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppAppHotel.Views.HospedagemContratada"
             Title="Hospedagem Contratada"
             BackgroundColor="#F5F5F5">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20" VerticalOptions="Center" HorizontalOptions="Center">
            <Label Text="Sua Reserva Foi Confirmada!" 
                   FontSize="28" 
                   FontFamily="KalamBold" 
                   HorizontalOptions="Center" 
                   TextColor="{StaticResource Primary}"
                   Margin="0,10,0,20"/>

            <Border StrokeShape="RoundRectangle 15" Padding="20" BackgroundColor="White" Stroke="Transparent">
                <VerticalStackLayout Spacing="15">
                    <Label Text="Detalhes da Reserva:" FontFamily="OpenSansSemibold" FontSize="18" TextColor="#333" />
                    <Label x:Name="lblResumo" 
                           FontSize="16" 
                           FontFamily="OpenSansRegular"
                           TextColor="#555" 
                           HorizontalTextAlignment="Start" />
                </VerticalStackLayout>
            </Border>

            <Button Text="Voltar para Contratação" 
                    Clicked="OnVoltarClicked" 
                    FontFamily="OpenSansSemibold"
                    CornerRadius="10"
                    Margin="0,20,0,0"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
