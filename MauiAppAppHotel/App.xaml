<?xml version="1.0" encoding="utf-8" ?>

<Application
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="MauiAppAppHotel.App">

    <Application.Resources>
        <ResourceDictionary>
            <Color x:Key="Primary">#007bff</Color>
            <Color x:Key="Secondary">#6c757d</Color>
            <Color x:Key="Accent">#fd7e14</Color>
            <Color x:Key="LightGray">#f8f9fa</Color>
            <Color x:Key="DarkGray">#343a40</Color>

            <Style TargetType="Button">
                <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
                <Setter Property="TextColor" Value="White" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="Padding" Value="12,10" />
                <Setter Property="FontSize" Value="16" />
            </Style>

            <Style TargetType="Label">
                <Setter Property="TextColor" Value="{StaticResource DarkGray}" />
                <Setter Property="FontSize" Value="16" />
            </Style>

            <Style x:Key="Headline" TargetType="Label">
                <Setter Property="TextColor" Value="{StaticResource Primary}" />
                <Setter Property="FontSize" Value="28" />
                <Setter Property="FontFamily" Value="KalamBold" />
            </Style>

            <Style x:Key="SubHeadline" TargetType="Label">
                <Setter Property="TextColor" Value="{StaticResource Secondary}" />
                <Setter Property="FontSize" Value="18" />
                <Setter Property="FontFamily" Value="OpenSansSemibold" />
            </Style>

            <Style TargetType="Entry">
                <Setter Property="PlaceholderColor" Value="{StaticResource Secondary}" />
                <Setter Property="TextColor" Value="{StaticResource DarkGray}" />
                <Setter Property="FontSize" Value="16" />
                <Setter Property="HeightRequest" Value="44" />
                <Setter Property="Margin" Value="0,5" />
            </Style>

            <Style TargetType="Picker">
                <Setter Property="TextColor" Value="{StaticResource DarkGray}" />
                <Setter Property="TitleColor" Value="{StaticResource Secondary}" />
                <Setter Property="FontSize" Value="16" />
                <Setter Property="HeightRequest" Value="44" />
                <Setter Property="Margin" Value="0,5" />
            </Style>

        </ResourceDictionary>
    </Application.Resources>

</Application>
